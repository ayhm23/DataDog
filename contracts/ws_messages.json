{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ws_messages.json",
  "title": "WebSocket Messages",
  "description": "Messages pushed from the websocket-gateway to connected dashboard clients.",
  "oneOf": [
    {
      "title": "MetricUpdate",
      "description": "Real-time aggregated metric snapshot for a service/resource.",
      "type": "object",
      "required": ["type", "timestamp", "service", "resource", "metrics"],
      "properties": {
        "type": { "type": "string", "const": "metric_update" },
        "timestamp": {
          "type": "integer",
          "description": "Unix epoch milliseconds"
        },
        "service": { "type": "string" },
        "resource": { "type": "string" },
        "metrics": {
          "type": "object",
          "properties": {
            "requestCount":  { "type": "integer" },
            "errorCount":    { "type": "integer" },
            "p50LatencyMs":  { "type": "number" },
            "p95LatencyMs":  { "type": "number" },
            "p99LatencyMs":  { "type": "number" },
            "throughputRps": { "type": "number" }
          }
        }
      }
    },
    {
      "title": "AnomalyAlert",
      "description": "Fired when the anomaly-worker detects a statistical outlier.",
      "type": "object",
      "required": ["type", "timestamp", "service", "resource", "severity", "description"],
      "properties": {
        "type": { "type": "string", "const": "anomaly_alert" },
        "timestamp": {
          "type": "integer",
          "description": "Unix epoch milliseconds"
        },
        "service": { "type": "string" },
        "resource": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "description": { "type": "string" },
        "value":    { "type": "number", "description": "Observed metric value" },
        "baseline": { "type": "number", "description": "Expected baseline value" }
      }
    },
    {
      "title": "Heartbeat",
      "description": "Keepalive ping from gateway; client should respond with pong.",
      "type": "object",
      "required": ["type", "timestamp"],
      "properties": {
        "type": { "type": "string", "const": "heartbeat" },
        "timestamp": { "type": "integer" }
      }
    }
  ]
}
