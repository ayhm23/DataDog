# ─────────────────────────────────────────────────────────────────────────────
# .env.example  — Copy to .env and fill in real values before running locally.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_METRICS_TOPIC=raw-metrics
KAFKA_ANOMALY_TOPIC=anomalies

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USER=root
MONGO_PASS=secret
MONGO_URI=mongodb://root:secret@mongo:27017/datadog?authSource=admin

# ── Ingestion Service ─────────────────────────────────────────────────────────
INGESTION_PORT=8080

# ── WebSocket Gateway ─────────────────────────────────────────────────────────
WS_PORT=8081

# ── Query API ─────────────────────────────────────────────────────────────────
QUERY_API_PORT=8082

# ── Dashboard ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8082
VITE_WS_URL=ws://localhost:8081

# ── Load Generator ────────────────────────────────────────────────────────────
LOAD_TARGET_URL=http://ingestion-service:8080
LOAD_RATE_RPS=500
LOAD_DURATION_SECONDS=300
